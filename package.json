{
  "name": "@watervein/monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "clean": "rimraf packages/*/dist && find packages -path '*/src/*' \\( -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' -o -name '*.d.ts.map' \\) -delete",
    "build": "pnpm run clean && pnpm --filter \"./packages/*\" run build",
    "bt": "pnpm build && pnpm test",
    "bench": "pnpm --filter @watervein/benchmark run dev",
    "example": "pnpm --filter @watervein/example run dev",
    "test": "NODE_OPTIONS=--expose-gc vitest run",
    "test:pnpm": "pnpm --filter \"./packages/*\" test",
    "test:watch": "NODE_OPTIONS=--expose-gc vitest"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
