{
  "name": "@watervein/dom",
  "version": "0.1.0",
  "description": "Watervein DOM package",
  "author": "Korphere",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm build:js && pnpm build:types",
    "build:js": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --platform=browser --external:@watervein/*",
    "build:types": "dts-bundle-generator -o dist/index.d.ts src/index.ts --external-imports @watervein/* --no-check"
  },
  "dependencies": {
    "@watervein/core": "workspace:*",
    "@watervein/dom-core": "workspace:*"
  },
  "devDependencies": {},
  "publishConfig": {
    "access": "public"
  }
}